# SQLite (development) — no setup required, database file will be created automatically
DATABASE_URL=sqlite:///./app.db

# PostgreSQL (production) — uncomment and fill in your credentials
# DATABASE_URL=postgresql://postgres:password@localhost:5432/app_db

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

